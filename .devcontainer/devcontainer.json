{
  "name": "MuJoCo Ant Project",

  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",

  // Alles System- und Python-Setup passiert im Skript, nicht hier.
  "postCreateCommand": "bash .devcontainer/setup.sh",

  "containerEnv": {
    // Codespaces hat keine GPU -> Software-Rendering. egl waere schneller,
    // braucht aber eine Grafikkarte.
    "MUJOCO_GL": "osmesa",
    "PYOPENGL_PLATFORM": "osmesa"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  },

  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  }
}
